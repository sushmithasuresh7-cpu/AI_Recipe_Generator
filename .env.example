# IBM watsonx.ai credentials
# Copy this file to .env and fill in your values

# IBM Cloud API Key — obtain from https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=your_ibm_cloud_api_key_here

# watsonx.ai Project ID — find in your watsonx.ai project settings
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# watsonx.ai regional endpoint (choose the one closest to you)
# US South  : https://us-south.ml.cloud.ibm.com
# EU (Frankfurt): https://eu-de.ml.cloud.ibm.com
# EU (London): https://eu-gb.ml.cloud.ibm.com
# AP (Tokyo): https://jp-tok.ml.cloud.ibm.com
# AP (Sydney): https://au-syd.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Optional: Flask secret key (auto-generated if not set)
# FLASK_SECRET=your_random_secret_key_here
